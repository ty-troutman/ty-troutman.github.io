@article{RN1355,
   author = {Murthy, A. K. and Chaganty, B. K. and Troutman, T. and Guentzel, M. N. and Yu, J. J. and Ali, S. K. and Lauriano, C. M. and Chambers, J. P. and Klose, K. E. and Arulanandam, B. P.},
   title = {Mannose-containing oligosaccharides of non-specific human secretory immunoglobulin A mediate inhibition of Vibrio cholerae biofilm formation},
