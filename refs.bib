@article{RN551,
   author = {Furlan, S. N. and Mandraju, R. and Brewer, T. and Roybal, K. and Troutman, T. D. and Hu, W. and Palm, N. W. and Unni, A. and Pasare, C.},
   title = {Enhancement of anti-tumor CD8 immunity by IgG1-mediated targeting of Fc receptors},
